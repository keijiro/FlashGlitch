:root {
}

.unity-label {
    color: rgb(255, 255, 255);
    max-width: 100px;
    min-width: 100px;
}

.spacer {
    height: 20px;
}

.container {
    width: 300px;
    margin-top: 30px;
    margin-right: 30px;
    margin-bottom: 30px;
    margin-left: 30px;
    padding-top: 12px;
    padding-right: 12px;
    padding-bottom: 12px;
    padding-left: 12px;
    background-color: rgba(0, 0, 0, 0.41);
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
    border-bottom-left-radius: 8px;
}

.trigger-button {
    width: 170px;
    height: 32px;
}
